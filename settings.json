{
  "hooks": {
    "SessionStart": [
      {
        "id": "observe-session-start",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "id": "observe-session-end",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-session-end.sh",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "id": "observe-subagent-start",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-subagent-start.sh",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "id": "observe-subagent-stop",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-subagent-stop.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "id": "observe-cost-tracker",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-cost-tracker.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "id": "observe-budget-alert",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-budget-alert.sh",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "id": "observe-tool-failure",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-cost-tracker.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "id": "observe-pre-compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-session-end.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "id": "observe-post-compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/observe-session-start.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
